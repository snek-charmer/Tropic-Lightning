# Address the HTTP server binds to.
LISTEN_ADDR=:3000

# Keycloak realm issuer URL (no trailing slash).
# Format: https://<keycloak-host>/realms/<realm-name>
KEYCLOAK_ISSUER=http://localhost:8080/realms/myrealm

# OIDC client credentials (create a confidential client in Keycloak).
OIDC_CLIENT_ID=keycloak-portal
OIDC_CLIENT_SECRET=change-me

# Must exactly match a Valid Redirect URI configured on the Keycloak client.
OIDC_REDIRECT_URL=http://localhost:3000/auth/callback

# Where Keycloak sends the browser after logout.
OIDC_POST_LOGOUT_REDIRECT_URL=http://localhost:3000/

# Scopes to request. "openid" is required; "roles" includes realm/client roles.
OIDC_SCOPES=openid profile email roles

# Set to "true" in production (HTTPS) so session cookies get the Secure flag.
COOKIE_SECURE=false

# Keycloak group whose members are admins (in addition to the "admin" realm
# role). Matches the token's "groups" claim (full path).
ADMIN_GROUP=/UDS Core/Admin

# peat node gRPC endpoint backing data-source storage. peat owns persistence,
# disconnected operation, and CRDT mesh sync.
PEAT_NODE_ADDR=localhost:50051

# peat document collection used for data sources.
PEAT_COLLECTION=data_sources

# Dial the peat node over TLS. Leave false for the co-located sidecar pattern
# (in-pod / localhost plaintext).
PEAT_TLS=false
